{
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^22.10.0",
    "lefthook": "^2.1.10",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "ultracite": "7.9.4"
  },
  "name": "@soralabsoss/sora-cli",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "type": "module",
  "version": "0.1.10",
  "description": "CLI to install components from any shadcn-compatible registry — defaults to Sora UI and other Sora Labs products",
  "license": "MIT",
  "author": "Axyl1410",
  "homepage": "https://ui.soralabs.io.vn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoraLabsOSS/sora-cli.git"
  },
  "keywords": [
    "cli",
    "components",
    "ui",
    "react",
    "tailwindcss",
    "motion",
    "shadcn",
    "sora"
  ],
  "bin": {
    "sora": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5"
}
