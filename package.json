{
  "name": "sora-cli",
  "version": "0.1.0",
  "description": "CLI to install Sora UI (and future Sora Labs) components into your project",
  "type": "module",
  "license": "MIT",
  "author": "Axyl1410",
  "homepage": "https://ui.soralabs.io.vn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axyl1410/sora-cli.git"
  },
  "keywords": ["cli", "components", "ui", "react", "tailwindcss", "motion", "shadcn", "sora"],
  "bin": {
    "sora": "dist/index.js"
  },
  "files": ["dist/index.js", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
